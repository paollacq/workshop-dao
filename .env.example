# ── Configuração do Workshop DAO ──────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o .env com chave privada real no GitHub.

# Chave privada da carteira do facilitador (sem o 0x no início)
PRIVATE_KEY=sua_chave_privada_aqui

# RPC da Sepolia — opções gratuitas:
#   https://rpc.sepolia.org  (público, sem cadastro)
#   https://sepolia.infura.io/v3/SEU_PROJECT_ID
#   https://eth-sepolia.g.alchemy.com/v2/SUA_API_KEY
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# API Key do Etherscan (para verificar contratos — opcional)
ETHERSCAN_API_KEY=

# Endereços dos contratos após o deploy (preenchidos pelo script deploy.js)
GOVTOKEN_ADDRESS=
TIMELOCK_ADDRESS=
GOVERNOR_ADDRESS=
TARGET_ADDRESS=
